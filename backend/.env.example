# ============================================================
# Application Environment Variables
# ============================================================

# Database connection string (for Prisma CLI / migrations)
# Replace 'your_db_user', 'your_db_password', and 'your_db_name' with your local MySQL credentials
DATABASE_URL="mysql://your_db_user:your_db_password@localhost:3306/your_db_name"

# Individual DB credentials (for Prisma Driver Adapter at runtime)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=ticketing_db

# Application port
PORT=3000

# JWT secret (change this in production!)
# Generate a strong random string for your local development
JWT_SECRET="generate_a_strong_secret_key_here"
JWT_EXPIRES_IN="7d"