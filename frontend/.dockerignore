# Dependencies — reinstalled inside the container
node_modules

# Next.js build output — rebuilt inside the container
.next

# Environment files — injected at runtime via docker-compose
.env
.env.*
.env.local
.env.*.local

# Editor and OS artefacts
.idea
.vscode
*.DS_Store

# Docker files (no need to copy into the image itself)
Dockerfile
.dockerignore

# Git
.git
.gitignore

# Logs
*.log
npm-debug.log*

# README (not needed in the image)
README.md
